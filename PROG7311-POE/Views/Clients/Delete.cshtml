@model PROG7311_POE.Models.Client

@{
    ViewData["Title"] = "Delete Client";
}

<h1>Delete Client</h1>

<div class="alert alert-danger">
    <h3>Are you sure you want to delete this client?</h3>
    <p>Deleting a client will also remove all associated contracts and service requests (if cascade configured).</p>
</div>

<div>
    <dl class="row">
        <dt class="col-sm-2">@Html.DisplayNameFor(model => model.Name)</dt>
        <dd class="col-sm-10">@Html.DisplayFor(model => model.Name)</dd>

        <dt class="col-sm-2">@Html.DisplayNameFor(model => model.ContactDetails)</dt>
        <dd class="col-sm-10">@Html.DisplayFor(model => model.ContactDetails)</dd>

        <dt class="col-sm-2">@Html.DisplayNameFor(model => model.Region)</dt>
        <dd class="col-sm-10">@Html.DisplayFor(model => model.Region)</dd>
    </dl>

    <form asp-action="Delete">
        <input type="hidden" asp-for="Id" />
        <input type="submit" value="Delete" class="btn btn-danger" />
        <a asp-action="Index" class="btn btn-secondary">Cancel</a>
    </form>
</div>