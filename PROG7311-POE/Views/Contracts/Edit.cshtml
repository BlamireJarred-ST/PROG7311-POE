@model PROG7311_POE.Models.Contract

@{
    ViewData["Title"] = "Edit Contract";
    var clients = ViewBag.Clients as List<PROG7311_POE.Models.Client>;
}

<h1>Edit Contract</h1>

<form asp-action="Edit" enctype="multipart/form-data" method="post">
    <input type="hidden" asp-for="Id" />
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <div class="form-group">
        <label asp-for="ClientId" class="control-label"></label>
        <select asp-for="ClientId" class="form-control">
            @if (clients != null)
            {
                foreach (var client in clients)
                {
                    <option value="@client.Id" selected="@(client.Id == Model.ClientId)">@client.Name</option>
                }
            }
        </select>
        <span asp-validation-for="ClientId" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="StartDate" class="control-label"></label>
        <input asp-for="StartDate" type="date" class="form-control" />
        <span asp-validation-for="StartDate" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="EndDate" class="control-label"></label>
        <input asp-for="EndDate" type="date" class="form-control" />
        <span asp-validation-for="EndDate" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="Status" class="control-label"></label>
        <select asp-for="Status" asp-items="Html.GetEnumSelectList<PROG7311_POE.Models.ContractStatus>()" class="form-control"></select>
        <span asp-validation-for="Status" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="ServiceLevel" class="control-label"></label>
        <input asp-for="ServiceLevel" class="form-control" />
        <span asp-validation-for="ServiceLevel" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label class="control-label">Current Signed Agreement</label>
        @if (!string.IsNullOrEmpty(Model.SignedAgreementPath))
        {
            <div>
                <a asp-action="DownloadFile" asp-route-id="@Model.Id" target="_blank">Download Current PDF</a>
            </div>
        }
        else
        {
            <span class="text-muted">No file uploaded.</span>
        }
    </div>

    <div class="form-group">
        <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div> 
        <label class="control-label">Upload New PDF (optional)</label>
        <input type="file" name="newSignedAgreement" class="form-control" accept=".pdf" />
        @Html.ValidationMessage("newSignedAgreement", new { @class = "text-danger" }) 
        <small class="form-text text-muted">If you upload a new file, it will replace the existing one.</small>
    </div>

    <div class="form-group mt-3">
        <input type="submit" value="Save" class="btn btn-primary" />
        <a asp-action="Index" class="btn btn-secondary">Back to List</a>
    </div>
</form>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}