@model PROG7311_POE.Models.Contract

@{
    ViewData["Title"] = "Delete Contract";
}

<h1>Delete Contract</h1>

<div class="alert alert-danger">
    <h3>Are you sure you want to delete this contract?</h3>
    <p>Deleting a contract will also remove all associated service requests.</p>
</div>

<div>
    <dl class="row">
        <dt class="col-sm-2">Client</dt>
        <dd class="col-sm-10">@Model.Client?.Name</dd>

        <dt class="col-sm-2">Start Date</dt>
        <dd class="col-sm-10">@Model.StartDate.ToShortDateString()</dd>

        <dt class="col-sm-2">End Date</dt>
        <dd class="col-sm-10">@Model.EndDate.ToShortDateString()</dd>

        <dt class="col-sm-2">Status</dt>
        <dd class="col-sm-10">@Model.Status</dd>
    </dl>

    <form asp-action="Delete">
        <input type="hidden" asp-for="Id" />
        <input type="submit" value="Delete" class="btn btn-danger" />
        <a asp-action="Index" class="btn btn-secondary">Cancel</a>
    </form>
</div>